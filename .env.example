# 🥷 ScalaNinja — Variáveis de Ambiente
# Copie para .env e preencha com seus valores reais
# NUNCA commite o arquivo .env!

# ─── SUPABASE (obrigatório — preenchido automaticamente pelo Lovable Cloud) ───
VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
VITE_SUPABASE_PROJECT_ID=xxxxxxxx

# ─── EDGE FUNCTIONS (Supabase Secrets) ──────────────────────────────
# Configure via: supabase secrets set NOME=valor
# Ou pelo painel Lovable Cloud → Secrets

# MercadoPago — Token da plataforma (cobranças de assinatura)
# MP_PLATFORM_ACCESS_TOKEN=APP_USR-xxx

# ElevenLabs — Geração de voz IA
# ELEVENLABS_API_KEY=sk_xxx

# Meta/Facebook — Webhook verify token
# META_WEBHOOK_VERIFY_TOKEN=scalaninja_verify_2026

# Criptografia de chaves de integração dos tenants
# APP_ENCRYPTION_KEY=64-chars-hex-random

# Token de proteção para seed de dados iniciais
# SETUP_SECRET=32-chars-hex-random
